# QueueStorm Investigator — environment variables
# The service runs fully rule-based by default and needs NO secrets to operate.
# All variables below are OPTIONAL.

# Port the service binds to (defaults to 8000). Bind host is always 0.0.0.0.
PORT=8000

# --- Optional LLM augmentation (OFF by default) ---
# The service does not require any LLM. If you choose to enable an optional
# hybrid mode in your own deployment, supply your OWN key here. Never commit a
# real value to git. Leave blank to keep the deterministic rule-based pipeline.
LLM_PROVIDER=
LLM_API_KEY=
LLM_MODEL=
